APP_NAME=EXAMIQ
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Use the same host you open in the browser (e.g. http://127.0.0.1:8000 with `php artisan serve`).
# Mismatching localhost vs 127.0.0.1 with the Vite dev server can break scripts/styles loading.
APP_URL=http://127.0.0.1:8000

# Vite dev server (optional). Defaults match artisan serve + npm run dev on 127.0.0.1.
# VITE_DEV_HOST=0.0.0.0
# VITE_DEV_PORT=5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=examiq_db
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

EXAMIQ_OTP_TTL=5
EXAMIQ_ALLOW_HOD_USER_MANAGEMENT=false
EXAMIQ_SMS_PROVIDER=log
EXAMIQ_OTP_LOG_FALLBACK_ENABLED=true
EXAMIQ_SUPER_ADMIN_PHONES=0200000000
EXAMIQ_SUPER_ADMIN_USERNAME=admin
EXAMIQ_SUPER_ADMIN_PASSWORD=Atomic2@2020^
ARKASEL_API_KEY=
ARKASEL_SENDER_ID=EXAMIQ
ARKASEL_BASE_URL=https://sms.arkesel.com/api/v2
# Optional: override login page hero image URL
# EXAMIQ_LOGIN_HERO_URL=
